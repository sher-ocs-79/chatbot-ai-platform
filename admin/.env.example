APP_NAME="WP Extractor"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Railway provides DATABASE_URL — set DB_URL to that value in Railway env vars
DB_URL=
# Or configure individual values:
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=wp_extractor
DB_USERNAME=laravel
DB_PASSWORD=

CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# Admin credentials used on first seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
